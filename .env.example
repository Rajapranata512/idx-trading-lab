# Data provider
EODHD_API_TOKEN=

# Optional notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public web operational auth
# Keep the premium dashboard public, and protect operational routes with these credentials.
IDX_WEB_USERNAME=ops
IDX_WEB_PASSWORD=change-this-before-public-hosting

# Public Docker/TLS deployment
IDX_PUBLIC_DOMAIN=example.com
LETSENCRYPT_EMAIL=ops@example.com
# Start with the bootstrap template, issue certs, then switch to ./deploy/nginx.prod.conf.template
IDX_NGINX_TEMPLATE=./deploy/nginx.bootstrap.conf.template

# Optional: only allow these IPs/CIDRs to open /ops-login.html
# Example: 127.0.0.1,203.0.113.10/32,203.0.113.0/24
IDX_WEB_OPS_LOGIN_ALLOWLIST=

# Optional: lightweight in-app rate limit for /ops-login.html
IDX_WEB_OPS_LOGIN_RATE_LIMIT_MAX_REQUESTS=12
IDX_WEB_OPS_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Optional: temporary lockout after repeated failed Basic Auth attempts
IDX_WEB_AUTH_LOCKOUT_MAX_FAILURES=5
IDX_WEB_AUTH_LOCKOUT_SECONDS=300
