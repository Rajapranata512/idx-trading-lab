limit_req_zone $binary_remote_addr zone=idx_ops_limit:10m rate=10r/m;

server {
    listen 80;
    server_name _;

    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    location / {
        proxy_pass http://idx-web:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location ~ ^/api/(jobs|run-daily|report-html|close-analysis|close-prices) {
        limit_req zone=idx_ops_limit burst=15 nodelay;
        proxy_pass http://idx-web:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location = /ops-login.html {
        allow 127.0.0.1;
        # allow 203.0.113.10/32;
        # allow 203.0.113.0/24;
        deny all;

        limit_req zone=idx_ops_limit burst=6 nodelay;
        proxy_pass http://idx-web:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /ops-report.html {
        allow 127.0.0.1;
        # allow 203.0.113.10/32;
        # allow 203.0.113.0/24;
        deny all;

        proxy_pass http://idx-web:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
